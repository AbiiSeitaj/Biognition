DATABASE_URL=sqlite:///./drscan.db
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Docker/local default API
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Tailscale Serve same-origin mode:
# Frontend: https://YOUR-MACHINE.tailnet.ts.net/
# API:      https://YOUR-MACHINE.tailnet.ts.net/api
# Leave NEXT_PUBLIC_API_URL unset when serving frontend and /api on the same host.
