DATABASE_URL=sqlite:///./drscan.db
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Docker/local: leave empty to use same-origin /api (proxied by Next.js)
NEXT_PUBLIC_API_URL=

# Next.js build-time proxy target (Docker service name or local backend)
API_PROXY_URL=http://127.0.0.1:8000

# Manual dev on port 8765:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8765
